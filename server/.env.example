# PostgreSQL connection string
# Railway provides this automatically as DATABASE_URL when you add a Postgres plugin.
# For local dev, use your local PostgreSQL URL or a Railway dev database URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Server
PORT=4000
NODE_ENV=development

# Auth — change this to a long random string in production!
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Platform economics
HOST_PAYOUT_PERCENT=70
COIN_TO_CURRENCY_RATE=0.01

# Google Play Billing server-side receipt verification.
GOOGLE_PLAY_PACKAGE_NAME="com.yourcompany.videochat"
GOOGLE_SERVICE_ACCOUNT_JSON_PATH="./google-service-account.json"
# Set to "true" to skip real Play verification during development.
SKIP_IAP_VERIFICATION=true

# WebRTC ICE servers
STUN_URL="stun:stun.l.google.com:19302"
TURN_URL=""
TURN_USERNAME=""
TURN_CREDENTIAL=""
