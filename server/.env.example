# SQLite database file (no installation needed for local development)
DATABASE_URL="file:./dev.db"

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Platform economics
# Percentage (0-100) of coins spent on a call that goes to the host; the rest is the platform's cut.
HOST_PAYOUT_PERCENT=70
# How many real-world coins a single "coin" costs the platform when a host cashes out (for admin reference only).
COIN_TO_CURRENCY_RATE=0.01

# Google Play Billing server-side receipt verification.
# Create a service account in Google Play Console > API access, grant it
# "View financial data" access, and download its JSON key.
GOOGLE_PLAY_PACKAGE_NAME="com.yourcompany.videochat"
GOOGLE_SERVICE_ACCOUNT_JSON_PATH="./google-service-account.json"
# Set to "true" to skip real Play verification and trust client-reported receipts.
# NEVER set this to true in production — it is only for local development without
# a configured Play Console app.
SKIP_IAP_VERIFICATION=true

# WebRTC ICE servers. The public STUN server works for testing; for production
# you need a TURN server (e.g. self-hosted coturn, or Twilio/Xirsys) so calls
# still connect when both users are behind restrictive NATs/firewalls.
STUN_URL="stun:stun.l.google.com:19302"
TURN_URL=""
TURN_USERNAME=""
TURN_CREDENTIAL=""
