generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  HOST
  ADMIN
}

enum TxType {
  PURCHASE
  CALL_SPEND
  CALL_EARN
  WITHDRAWAL
  ADJUSTMENT
}

enum CallStatus {
  REQUESTED
  ACCEPTED
  ONGOING
  ENDED
  REJECTED
  MISSED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet       Wallet?
  hostProfile  HostProfile?
  transactions CoinTransaction[]
  iapReceipts  IapReceipt[]

  callsMade     Call[] @relation("CallerCalls")
  callsReceived Call[] @relation("HostCalls")
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  coinBalance Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model CoinTransaction {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         TxType
  amount       Int
  balanceAfter Int
  callId       String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model IapReceipt {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  productId     String
  purchaseToken String   @unique
  orderId       String?
  coinsCredited Int
  createdAt     DateTime @default(now())
}

model HostProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  bio              String?
  country          String?
  age              Int?
  gender           String?
  language         String?  // e.g. Arabic, Spanish, Asian, English, Europe
  ratePerMinute    Int      @default(10)
  isOnline         Boolean  @default(false)
  isApproved       Boolean  @default(false)
  totalEarnedCoins Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  withdrawals WithdrawalRequest[]
}

model Call {
  id              String     @id @default(uuid())
  callerId        String
  caller          User       @relation("CallerCalls", fields: [callerId], references: [id])
  hostId          String
  host            User       @relation("HostCalls", fields: [hostId], references: [id])
  status          CallStatus @default(REQUESTED)
  ratePerMinute   Int
  startedAt       DateTime?
  endedAt         DateTime?
  durationSeconds Int        @default(0)
  coinsSpent      Int        @default(0)
  endReason       String?
  createdAt       DateTime   @default(now())

  @@index([callerId])
  @@index([hostId])
}

model WithdrawalRequest {
  id          String           @id @default(uuid())
  hostId      String
  hostProfile HostProfile      @relation(fields: [hostId], references: [id])
  coinsAmount Int
  status      WithdrawalStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  processedAt DateTime?
  note        String?
}

// A user blocking another user. Blocked users are hidden from each other in
// host discovery and cannot start calls with each other. Required by Google
// Play for apps with user-to-user interaction.
model UserBlock {
  id            String   @id @default(uuid())
  blockerUserId String
  blockedUserId String
  createdAt     DateTime @default(now())

  @@unique([blockerUserId, blockedUserId])
  @@index([blockerUserId])
  @@index([blockedUserId])
}

// A report filed by one user against another (optionally tied to a call).
// Reviewed by an admin. Required by Google Play so users can flag abuse.
model UserReport {
  id             String       @id @default(uuid())
  reporterUserId String
  reportedUserId String
  callId         String?
  reason         String
  details        String?
  status         ReportStatus @default(OPEN)
  createdAt      DateTime     @default(now())
  reviewedAt     DateTime?

  @@index([reportedUserId])
  @@index([status])
}
